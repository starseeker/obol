        -:   51:/* ********************************************************************** */
        -:   52:
        -:   53:/* Some useful inline template functions:
        -:   54: *   SbAbs(Val)              - returns absolute value
        -:   55: *   SbMin(Val1, Val2)       - returns minimum value
        -:   56: *   SbMax(Val1, Val2)       - returns maximum value
        -:   57: *   SbClamp(Val, Min, Max)  - returns clamped value
        -:   58: *   SbSwap(Val1, Val2)      - swaps the two values (no return value)
        -:   59: *   SbSqr(val)              - returns squared value
        -:   60: */
        -:   61:
        -:   62:template <typename Type>
        -:   63:constexpr Type SbAbs( Type Val ) noexcept {
        -:   64:  return (Val < 0) ? 0 - Val : Val;
        -:   65:}
        -:   66:
        -:   67:template <typename Type>
        -:   68:constexpr Type SbMax( const Type A, const Type B ) noexcept {
        -:   69:  return (A < B) ? B : A;
        -:   70:}
        -:   71:
        -:   72:template <typename Type>
        -:   73:constexpr Type SbMin( const Type A, const Type B ) noexcept {
        -:   74:  return (A < B) ? A : B;
        -:   75:}
        -:   76:
        -:   77:template <typename Type>
        -:   78:constexpr Type SbClamp( const Type Val, const Type Min, const Type Max ) noexcept {
        -:   79:  return (Val < Min) ? Min : (Val > Max) ? Max : Val;
        -:   80:}
        -:   81:
        -:   82:template <typename Type>
        -:   83:constexpr void SbSwap( Type & A, Type & B ) noexcept {
        -:   84:  Type T = A; A = B; B = T;
        -:   85:}
        -:   86:
        -:   87:template <typename Type>
        -:   88:constexpr Type SbSqr(const Type val) noexcept {
        -:   89:  return val * val;
        -:   90:}
        -:   91:
