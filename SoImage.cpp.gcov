        -:   32:
        -:   33:/*!
        -:   34:  \class SoImage SoImage.h Inventor/nodes/SoImage.h
        -:   35:  \brief The SoImage class draws a 2D image on the viewport.
        -:   36:
        -:   37:  \ingroup coin_nodes
        -:   38:
        -:   39:  An image can be specified either by using the image field, or by
        -:   40:  specifying a filename. If width and/or height is specified, the
        -:   41:  image will be resized to match those values before it is displayed.
        -:   42:
        -:   43:  The current modelview matrix will be used to find the viewport
        -:   44:  position, and the image is rendered in that position, with
        -:   45:  z-buffer testing activated.
        -:   46:
        -:   47:  Here's a simple, standalone example on how to set up and show an
        -:   48:  SoImage:
        -:   49:
        -:   50:  \code
        -:   51:  #include <cstdlib>
        -:   52:#include "glue/glp.h"
        -:   53:  #include <Inventor/Qt/SoQt.h>
        -:   54:  #include <Inventor/Qt/viewers/SoQtExaminerViewer.h>
        -:   55:  #include <Inventor/nodes/SoSeparator.h>
        -:   56:  #include <Inventor/nodes/SoCamera.h>
        -:   57:  #include <Inventor/nodes/SoCube.h>
        -:   58:  #include <Inventor/nodes/SoImage.h>
        -:   59:
        -:   60:  static void
        -:   61:  mandel(double sr, double si, double width, double height,
        -:   62:         int bwidth, int bheight, int mult, unsigned char * bmp, int n)
        -:   63:  {
        -:   64:    double zr, zr_old, zi, cr, ci;
        -:   65:    int w;
        -:   66:
        -:   67:    for (int y=0; y<bheight; y++)
        -:   68:      for (int x=0; x<bwidth; x++) {
        -:   69:        cr = ((double)(x)/(double)(bwidth))*width+sr;
        -:   70:        ci = ((double)(y)/(double)(bheight))*height+si;
        -:   71:        zr = zi = 0.0;
        -:   72:        for (w = 0; (w < n) && (zr*zr + zi*zi)<n; w++) {
        -:   73:          zr_old = zr;
        -:   74:          zr = zr*zr - zi*zi + cr;
        -:   75:          zi = 2*zr_old*zi + ci;
        -:   76:        }
        -:   77:        bmp[y*bwidth+x] = w*mult;
        -:   78:      }
        -:   79:  }
        -:   80:
        -:   81:  int
        -:   82:  main(int argc, char ** argv)
        -:   83:  {
        -:   84:    QWidget * mainwin = SoQt::init(argv[0]);
        -:   85:
        -:   86:    SoSeparator * root = new SoSeparator;
        -:   87:    root->ref();
        -:   88:
        -:   89:    const int IMGWIDTH = 256;
        -:   90:    const int IMGHEIGHT = 256;
        -:   91:    unsigned char * img = new unsigned char[IMGWIDTH * IMGHEIGHT];
        -:   92:    mandel(-0.5, 0.6, 0.025, 0.025, IMGWIDTH, IMGHEIGHT, 1, img, 256);
        -:   93:
        -:   94:    SoImage * nimage = new SoImage;
        -:   95:    nimage->vertAlignment = SoImage::HALF;
        -:   96:    nimage->horAlignment = SoImage::CENTER;
        -:   97:    nimage->image.setValue(SbVec2s(IMGWIDTH, IMGHEIGHT), 1, img);
        -:   98:
        -:   99:    SoCube * cube = new SoCube;
        -:  100:
        -:  101:    root->addChild(cube);
        -:  102:    root->addChild(nimage);
        -:  103:
        -:  104:    SoQtExaminerViewer * viewer = new SoQtExaminerViewer(mainwin);
        -:  105:    viewer->setSceneGraph(root);
        -:  106:    viewer->setTitle("SoImage use");
        -:  107:    viewer->show();
        -:  108:
        -:  109:    SoCamera * cam = viewer->getCamera();
        -:  110:    cam->position = SbVec3f(0, 0, 50);
        -:  111:    cam->focalDistance = 50;
        -:  112:
        -:  113:    SoQt::show(mainwin);
        -:  114:    SoQt::mainLoop();
        -:  115:
        -:  116:    delete viewer;
        -:  117:    root->unref();
        -:  118:    delete img;
        -:  119:    return 0;
        -:  120:  }
        -:  121:  \endcode
        -:  122:
        -:  123:  Note that an SoImage node in the scene graph will have its
        -:  124:  positioning / rendering influenced by the current viewport and
        -:  125:  camera. This has important implications for how to layout your scene
        -:  126:  graph for the best possible rendering performance. See the note
        -:  127:  about this issue in the SoText2 class documentation.
        -:  128:
        -:  129:  SoScale nodes cannot be used to influence the dimensions of the
        -:  130:  rendering output of SoImage nodes.
        -:  131:
        -:  132:  <b>FILE FORMAT/DEFAULTS:</b>
        -:  133:  \code
        -:  134:    Image {
        -:  135:        width -1
        -:  136:        height -1
        -:  137:        vertAlignment BOTTOM
        -:  138:        horAlignment LEFT
        -:  139:        image 0 0 0
        -:  140:
        -:  141:        filename ""
        -:  142:    }
        -:  143:  \endcode
        -:  144:
        -:  145:  \since TGS Inventor 2.5
        -:  146:  \since Coin 1.0
        -:  147:*/
