#include "Inventor/basic.h"

#ifdef __FILE__
#define OBOL_STUB_FILE __FILE__
#else
#define OBOL_STUB_FILE ((const char *)0L)
#endif

#ifdef __LINE__
#define OBOL_STUB_LINE __LINE__
#else
#define OBOL_STUB_LINE 0
#endif

#ifdef __cplusplus
#ifdef HAVE_CPP_COMPILER_FUNCTION_NAME_VAR
#define OBOL_STUB_FUNC HAVE_CPP_COMPILER_FUNCTION_NAME_VAR
#define OBOL_STUB_FUNC_STRING  OBOL_STUB_FUNC
#else
#define OBOL_STUB_FUNC ((const char *)0L)
#define OBOL_STUB_FUNC_STRING  "<>"
#endif
#else /* !__cplusplus */
#ifdef HAVE_C_COMPILER_FUNCTION_NAME_VAR
#define OBOL_STUB_FUNC HAVE_C_COMPILER_FUNCTION_NAME_VAR
#else
#define OBOL_STUB_FUNC ((const char *)0L)
#endif
#endif /* !__cplusplus */


/*
  OBOL_STUB(): this is the method which prints out stub
  information. Used where there is functionality missing.

  OBOL_OBSOLETED: this is the method which prints out obsoleted
  information. Used where there is an obsoleted or unsupported
  function. Typically a function that we feel should have been private
  in Open Inventor.
*/

#if OBOL_DEBUG

#include <Inventor/errors/SoDebugError.h>

#define OBOL_STUB() \
  do { \
    SbString s; \
    s.sprintf("%s:%u:%s", \
              OBOL_STUB_FILE ? OBOL_STUB_FILE : "<>", \
              OBOL_STUB_LINE, \
              OBOL_STUB_FUNC_STRING); \
    SoDebugError::postWarning(s.getString(), \
                              "STUB: functionality not yet completed"); \
  } while (0)

#define OBOL_STUB_ONCE() \
  do { \
    static int first = 1; \
    if (first) { \
      SbString s; \
      s.sprintf("%s:%u:%s", \
                OBOL_STUB_FILE ? OBOL_STUB_FILE : "<>", \
                OBOL_STUB_LINE, \
                OBOL_STUB_FUNC_STRING); \
      SoDebugError::postWarning(s.getString(), \
                                "STUB: functionality not yet completed"); \
      first = 0; \
    } \
  } while (0)

#define OBOL_OBSOLETED() \
  do { \
    SbString s; \
    s.sprintf("%s:%u:%s", \
              OBOL_STUB_FILE ? OBOL_STUB_FILE : "<>", \
              OBOL_STUB_LINE, \
              OBOL_STUB_FUNC_STRING); \
    SoDebugError::post(s.getString(), \
                       "OBSOLETED: functionality not supported (any more)"); \
  } while (0)

#else /* !OBOL_DEBUG */

#define OBOL_STUB()       do { } while (0)
#define OBOL_OBSOLETED()  do { } while (0)
#define OBOL_STUB_ONCE()  do { } while (0)

#endif /* !OBOL_DEBUG */

#ifdef __GNUC__
#define OBOL_UNUSED_ARG(x) x __attribute__((__unused__))
#else
#define OBOL_UNUSED_ARG(x) x
#endif


/* COMPILE_ONLY_BEFORE() - C++17 static_assert-based compile-time version guard */
#define COMPILE_ONLY_BEFORE(MAJOR,MINOR,MICRO,REASON) \
  static_assert( (OBOL_MAJOR_VERSION < MAJOR) || (OBOL_MAJOR_VERSION == MAJOR && ((OBOL_MINOR_VERSION < MINOR) || (OBOL_MINOR_VERSION == MINOR && (OBOL_MICRO_VERSION < MICRO)))), REASON )

#define COMPILE_ONLY_BEFORE_NOFUNCTION(MAJOR,MINOR,MICRO,REASON) \
  COMPILE_ONLY_BEFORE(MAJOR,MINOR,MICRO,REASON)

/*
  Grep for POTENTIAL_ROTTING_DOCUMENTATION and update the version
  number when you have checked all occurrences of this. Some places
  this marker is used in a pure comment, so do not content yourself
  with checking every place that fails.
*/
#define POTENTIAL_ROTTING_DOCUMENTATION COMPILE_ONLY_BEFORE_NOFUNCTION(4,0,1,"This piece of documentation may potentially be outdated in the future.")


#ifdef HAVE___BUILTIN_EXPECT
/* for branch-prediction hint optimization */
#ifndef likely
#define likely(cond)      (__builtin_expect(!!(cond), 1))
#endif /* !likely */
#ifndef unlikely
#define unlikely(cond)    (__builtin_expect(!!(cond), 0))
#endif /* !unlikely */
#else /* !HAVE___BUILTIN_EXPECT */
#ifndef likely
#define likely(cond)      (cond)
#endif /* !likely */
#ifndef unlikely
#define unlikely(cond)    (cond)
#endif /* !unlikely */
#endif /* !HAVE___BUILTIN_EXPECT */

#ifdef OBOL_DEBUG_CHECK_THREAD

#include <thread>

inline std::thread::id& coin_get_thread()
{
  static std::thread::id tid;
  return tid;
}

#define OBOL_INIT_CHECK_THREAD() \
  do { \
    coin_get_thread() = std::this_thread::get_id(); \
  } while (0)

#define OBOL_CHECK_THREAD() \
  do { \
    if (coin_get_thread() != std::this_thread::get_id()) { \
      SbString s; \
      s.sprintf("%s:%u:%s", \
                OBOL_STUB_FILE ? OBOL_STUB_FILE : "<>", \
                OBOL_STUB_LINE, \
                OBOL_STUB_FUNC_STRING); \
      SoDebugError::post(s.getString(), \
                         "Inventor access from wrong thread."); \
    } \
  } while (0)

#else /* OBOL_DEBUG_CHECK_THREAD */
#define OBOL_INIT_CHECK_THREAD() do { } while (0)
#define OBOL_CHECK_THREAD()      do { } while (0)
#endif /* OBOL_DEBUG_CHECK_THREAD */

#endif /* OBOL_CONFIG_H */
