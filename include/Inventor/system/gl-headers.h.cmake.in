/*
 * This header file is supposed to take care of all operating system
 * dependent anomalies connected to including the gl.h header file.
 */

/* This define is at least needed before inclusion of the header files
   that are part of NVidia's Linux drivers v41.91. Without it, none of
   the extension and OpenGL 1.1+ function prototypes will be set up.
   In OBOL_NO_OPENGL builds this is omitted to avoid accidentally pulling
   in real GL headers via the extension-prototype path. */
@SIM_GL_GLEXT_PROTOTYPES_DEFINE@

@SIM_INCLUDE_WINDOWS_H@

/* When OBOL_GLHEADERS_OSMESA_OVERRIDE is defined (set by _osmesa.cpp
   compilation units in dual-GL builds), we use OSMesa headers regardless
   of the default backend configured at CMake time.  This is the mechanism
   that allows src/glue/gl_osmesa.cpp to compile the same source with
   OSMesa GL symbols while the primary build uses system OpenGL. */
#ifdef OBOL_GLHEADERS_OSMESA_OVERRIDE
#  include <OSMesa/osmesa.h>
#  include <OSMesa/gl.h>
/* OSMesa/gl.h already includes OSMesa/glext.h */
#else
@SIM_INCLUDE_GL_H@
@SIM_INCLUDE_GLEXT_H@
#endif /* OBOL_GLHEADERS_OSMESA_OVERRIDE */

/* PortableGL defines its GL constants as sequential C enum members (not as
 * preprocessor macros).  This means the #ifndef guards in Inventor/system/gl.h
 * do NOT protect them from being overridden by the standard-GL hex constant
 * #defines in that file.  Work around this by promoting every portablegl enum
 * constant to a preprocessor macro (self-referential #define) immediately after
 * portablegl.h is included.  A self-referential #define is safe in C/C++ — the
 * preprocessor expands it once and stops, leaving the enum member as the value.
 * The crucial effect is that #ifndef GL_ARRAY_BUFFER now evaluates to FALSE,
 * preventing gl.h from replacing portablegl's sequential value with 0x8892.   */
#if defined(OBOL_PORTABLEGL_BUILD) && !defined(OBOL_GLHEADERS_OSMESA_OVERRIDE)
